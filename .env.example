# Copy to .env.local and fill in. .env.local is gitignored and must never be committed.

# --- Public. Safe in the browser bundle. ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# VAPID public key. The browser needs it to call pushManager.subscribe, so it
# ships in the bundle by design. Generate the pair with:
#   npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Sentry DSN for the browser. A DSN is public — it identifies where to send
# events, it does not authorise anything. Do not confuse it with
# SENTRY_AUTH_TOKEN below, which is a secret and is configured minutes apart.
VITE_SENTRY_DSN=

# --- Secret. Server-side and tooling only. Never referenced from apps/web. ---

# Postgres direct connection, used to apply migrations.
# Supabase Dashboard -> Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase CLI auth, used to deploy Edge Functions.
# https://supabase.com/dashboard/account/tokens -> Generate new token
SUPABASE_ACCESS_TOKEN=sbp_...

# Supabase secret key. Bypasses RLS. Used only inside Edge Functions.
# Dashboard -> Settings -> API Keys -> secret key
SUPABASE_SECRET_KEY=sb_secret_...

# Anthropic API key, used by the triage Edge Function.
# https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# VAPID private key, the other half of VITE_VAPID_PUBLIC_KEY above. Signing a
# push request takes the whole keypair, so the *public* key is also configured
# as a Supabase function secret under the unprefixed name VAPID_PUBLIC_KEY —
# four values in total, not two. VAPID_SUBJECT is a mailto: or https: URL
# identifying the sender and is required by the spec; omitting it throws at
# send time rather than at deploy time.
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=https://app.example.com

# Sentry. The DSN above is public; this token is not — it uploads sourcemaps.
# The org is in the EU region, so SENTRY_URL must be set: sentry-cli and
# @sentry/vite-plugin default to sentry.io (US) and fail as "project not found".
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_DSN=

# GitHub, for Stage 5. Fine-grained token scoped to this one repository with
# `issues: write` and nothing else — Reeve files issues, it does not push code.
GITHUB_ISSUES_TOKEN=github_pat_...
GITHUB_WEBHOOK_SECRET=
